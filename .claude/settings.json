{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(cargo build*)",
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo run*)",
      "Bash(cargo fmt*)",
      "Bash(cargo clippy*)",
      "Bash(cargo sqlx prepare*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose build*)",
      "Bash(lake build*)"
    ],
    "deny": [
      "Read(./human-guide/**)",
      "Edit(./human-guide/**)",
      "Write(./human-guide/**)"
    ]
  },
  "enabledMcpjsonServers": [
    "context7",
    "playwright"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/remind-decision-log.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
