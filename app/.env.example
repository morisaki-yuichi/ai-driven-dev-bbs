# ホストの cargo から `docker compose up -d db` のDBコンテナに接続する開発用設定。
# db コンテナ内の app(compose.yaml)から見た "db:5432" とは異なり、
# ホスト側からはポートマッピング経由の "localhost:5432" を指す。
# 使い方: このファイルを .env にコピーする(cp .env.example .env)。
# 値は .env.example (リポジトリ直下)の POSTGRES_USER/PASSWORD/DB と揃えてある。
DATABASE_URL=postgres://bbs:bbs@localhost:5432/bbs
