{
  "db_name": "PostgreSQL",
  "query": "\n        select comments.id,\n               comments.author_id,\n               users.display_name as author_display_name,\n               comments.body,\n               comments.created_at,\n               (comments.deleted_at is not null) as \"deleted!\"\n        from comments\n        join users on users.id = comments.author_id\n        where comments.thread_id = $1\n        order by comments.created_at asc, comments.id asc\n        ",
